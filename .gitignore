# --- System Files ---
.DS_Store
Thumbs.db
*.swp
*.tmp

# --- Node / pnpm ---
node_modules/
.pnpm-debug.log*
.npm-debug.log*
# Only ignore if you explicitly configured pnpm to use a local store
.pnpm-store/

# --- Build Outputs ---
dist/
build/
out/
.next/
# Three.js / WebGL specific (if you use custom shaders or temporary builds)
public/build/

# --- Environment / Secrets ---
.env
.env.local
.env.*.local
!.env.example

# --- IDEs ---
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# --- Python (Virtual Envs) ---
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.python-version

# --- Testing / Coverage ---
coverage/
.nyc_output/

# --- Documentation (LaTeX) ---
*.aux
*.fdb_latexmk
*.fls
*.gz
*.log
*.out
*.toc
*.synctex.gz

# --- Python (Virtual Envs & Conda) ---
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/
ENV/
.python-version

# --- Conda specific ---
.condarc
conda-meta/

# --- Cython / Scientific Python ---
*.so
.ipynb_checkpoints
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Graphics/CV specific ---
